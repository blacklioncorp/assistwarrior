      "name": "Clasificar intención",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 2,
      "position": [
        1450,
        200
      ],
      "credentials": {
        "openAiApi": "OpenAI"
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.choices[0].message.content;\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\nconst parsed = match ? JSON.parse(match[0]) : { intent: \"other\", parameters: {} };\nreturn parsed;"
      },
      "id": "node-7a",
      "name": "Parsear JSON de OpenAI",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        200
      ]
    },
    {
      "parameters": {
        "dataProperty": "intent",
        "rules": [
          {
            "value": "schedule",
            "output": 0
          },
          {
            "value": "reschedule",
            "output": 0
          },
          {
            "value": "cancel",
            "output": 1
          },
          {
            "value": "confirm",
            "output": 2
          },
          {
            "value": "question",
            "output": 3
          },
          {
            "value": "other",
            "output": 3
          }
        ]
      },
