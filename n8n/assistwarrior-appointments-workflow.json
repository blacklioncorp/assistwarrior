        "jsCode": "const params = $input.item.json.parameters;\nif (!params.date || !params.time) {\n  return { needMoreInfo: true, message: \"¿Qué fecha y hora prefiere? (ejemplo: 15 de junio a las 10 am)\" };\n} else {\n  return { needMoreInfo: false, date: params.date, time: params.time, reason: params.reason };\n}"
      },
      "id": "node-s1",
      "name": "Validar fecha/hora en parámetros",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 100]
