        "promptType": "define",
        "text": "={{ $('Extraer datos del mensaje').item.json.message }}",
        "systemPrompt": "Eres un clasificador de intenciones para un consultorio médico. Devuelve SOLO un JSON válido con esta estructura:\n{\n  \"intent\": \"schedule\" | \"cancel\" | \"reschedule\" | \"confirm\" (ejemplos: \"sí\", \"si\", \"confirmo\", \"de acuerdo\", \"va\", \"dale\", \"ok\", \"perfecto\", \"acepto\") | \"question\" | \"other\",\n  \"parameters\": {\n    \"date\": \"YYYY-MM-DD o null\",\n    \"time\": \"HH:MM o null\",\n    \"reason\": \"texto o null\"\n  }\n}"
      },
