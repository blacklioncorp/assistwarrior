      "parameters": {
        "dataProperty": "intent",
        "rules": [
          { "value": "schedule",   "output": 0 },
          { "value": "reschedule", "output": 0 },
          { "value": "cancel",     "output": 1 },
          { "value": "confirm",    "output": 2 },
          { "value": "question",   "output": 3 },
          { "value": "other",      "output": 3 }
        ]
      },
