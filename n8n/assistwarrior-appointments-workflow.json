      "id": "node-1",
      "name": "WhatsApp Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "whatsapp-trigger"
    },
    {
      "parameters": {
        "jsCode": "const msg = $input.item.json;\nconst entry = msg.entry?.[0];\nconst change = entry?.changes?.[0];\nconst value = change?.value;\nconst message = value?.messages?.[0];\n\nreturn {\n  phone: message?.from,\n  message: message?.text?.body,\n  businessPhoneId: value?.metadata?.phone_number_id,\n  messageId: message?.id\n};"
      },
      "id": "node-2",
      "name": "Extraer datos del mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "operation": "select",
        "table": "professionals",
        "columns": "*",
        "filters": {
          "conditions": [
            {
              "field": "whatsapp_phone_number_id",
              "operator": "eq",
              "value": "={{ $json.businessPhoneId }}"
            }
          ]
        },
        "limit": 1
      },
      "id": "node-3",
      "name": "Buscar profesional",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [650, 300],
      "credentials": {
        "supabaseApi": "Supabase"
      }
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.is_active === true && ($json.plan_status === 'active' || $json.plan_status === 'trialing') ? 1 : 0 }}",
              "operation": "equal",
              "value2": 1
            }
          ]
        }
      },
